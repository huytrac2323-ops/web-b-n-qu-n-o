@model List<Demo.Models.User>

@{
    ViewData["Title"] = "Users";
}

<h2>Users</h2>

<p><a class="btn btn-primary" href="/Users/Create">Create User</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Username</th>
            <th>Roles</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var u in Model)
    {
        <tr>
            <td>@u.Id</td>
            <td>@u.Username</td>
            <td>@u.Roles</td>
            <td>
                <a class="btn btn-sm btn-secondary" href="/Users/Edit/@u.Id">Edit</a>
                <form asp-action="Delete" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@u.Id" />
                    <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
