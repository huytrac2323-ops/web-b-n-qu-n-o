@model Demo.Models.CustomerAddress

@{
    ViewData["Title"] = "Delete Address";
}

<h1>Delete Address</h1>

<h3>Are you sure you want to delete this address?</h3>
<div>
    <h4>@Model.AddressLine</h4>
    <dl class="row">
        <dt class="col-sm-2">City</dt>
        <dd class="col-sm-10">@Model.City</dd>
        <dt class="col-sm-2">Country</dt>
        <dd class="col-sm-10">@Model.Country</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-controller="Customers" asp-action="Details" asp-route-id="@Model.CustomerId" class="btn btn-secondary">Cancel</a>
    </form>
</div>
